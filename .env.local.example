# Optional local overrides for BookTok Factory.
# Leave blank for the default local MVP paths.

# Absolute path to the project root. Defaults to the current working directory.
BOOKTOK_PROJECT_ROOT=

# Absolute path to the SQLite file. Defaults to data/booktok-factory.sqlite.
BOOKTOK_DATABASE_PATH=

# Optional Google Drive integration.
# Leave blank to keep the app fully local-only.
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_PROJECT_ID=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Optional path to a local service account JSON file.
# If set, this can be used instead of GOOGLE_CLIENT_EMAIL / GOOGLE_PRIVATE_KEY.
GOOGLE_APPLICATION_CREDENTIALS=

# Optional OAuth credentials for Drive/Sheets writes owned by a real Google user.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_JSON=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/oauth2callback
GOOGLE_OAUTH_TOKEN_PATH=data/google-oauth-token.json

# Authorloom worker queue connection.
AUTHORLOOM_CONVEX_URL=
AUTHORLOOM_WORKER_SECRET=
AUTHORLOOM_WORKER_ID=
AUTHORLOOM_WORKER_POLL_MS=10000
