# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local runtime data
/data/*.sqlite
/data/*.sqlite-*
/data/*.pid
/data/*.log
/data/*.txt
/data/logs/
/data/backups/
/storage/**/*
!/storage/**/
!/storage/**/.gitkeep
service-account.json
/data/google-oauth-token.json
google-oauth-client.json
google_oauth_client.json
data/google-oauth-token.json
service-account.json
.env.local
